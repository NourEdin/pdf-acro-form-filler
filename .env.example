# Contract template filenames (files sit in contracts/ and public/contracts/, not in git).
# Copy this file to .env before npm run dev / npm run build / npm run dump:pdf-fields.
# VITE_ prefix is required for Vite to expose values to the browser.

VITE_CONTRACT_PDF_SALALAH_LOCAL="Salalah Beach [local].pdf"
VITE_CONTRACT_PDF_SALALAH_INTERNATIONAL="Salalah Beach [international].pdf"
VITE_CONTRACT_PDF_SIFAH_LOCAL="Sifah [local].pdf"
VITE_CONTRACT_PDF_SIFAH_INTERNATIONAL="Sifah [international].pdf"
